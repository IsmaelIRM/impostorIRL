{
  "name": "reallife-amongus",
  "version": "1.0.0",
  "description": "Real-life Among Us party web app (non-commercial, one-off)",
  "main": "server.js",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "node server.js",
    "dev:server": "cd apps/server && npm run dev",
    "dev:web": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\""
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.23.0",
    "typescript": "^5.5.0"
  }
}
